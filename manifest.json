{
  "manifest_version": 3,
  "name": "20秒自動客服助手",
  "version": "1.2",
  "permissions": ["storage", "notifications", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gh.xchatclub.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}